{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MindChain Wallet",
  "version": "0.1.0",
  "identifier": "network.mindchain.noosphere.wallet",
  "build": {
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MindChain Wallet",
        "width": 1000,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MindChain",
    "copyright": "Copyright 2026 MindChain",
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

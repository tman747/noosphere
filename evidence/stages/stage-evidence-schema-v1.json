{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:noos:stage-evidence:v1",
  "title": "Immutable NOOSPHERE stage evidence bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "stage", "protocol_binding", "execution", "inputs", "raw_artifacts", "evaluation", "rollback", "producer", "signatures"],
  "properties": {
    "schema_version": {"const": 1},
    "bundle_id": {"type":"string","pattern":"^[A-Za-z0-9._-]+$"},
    "stage": {"enum":["G0","G1","G2","G3","GENESIS","G4","G5"]},
    "protocol_binding": {
      "type":"object","additionalProperties":false,"required":["revision","protocol_version","api_version","release_version","chain_id","genesis_hash"],
      "properties":{"revision":{"type":"string","minLength":1},"protocol_version":{"type":"string","minLength":1},"api_version":{"type":"string","minLength":1},"release_version":{"type":"string","minLength":1},"chain_id":{"type":"string","minLength":1},"genesis_hash":{"type":"string","minLength":1}}
    },
    "execution": {
      "type":"object","additionalProperties":false,"required":["command","cwd","toolchain_environment","started_at_utc","ended_at_utc","exit_code"],
      "properties":{"command":{"type":"array","minItems":1,"items":{"type":"string"}},"cwd":{"type":"string","minLength":1},"toolchain_environment":{"type":"object"},"started_at_utc":{"type":"string","format":"date-time"},"ended_at_utc":{"type":"string","format":"date-time"},"exit_code":{"type":"integer"}}
    },
    "inputs": {
      "type":"object","additionalProperties":false,"required":["fixtures","seeds"],
      "properties":{"fixtures":{"type":"array","items":{"$ref":"#/$defs/hashed_file"}},"seeds":{"type":"array","items":{"type":["string","integer"]}}}
    },
    "raw_artifacts": {"type":"array","minItems":2,"items":{"$ref":"#/$defs/hashed_file"}},
    "evaluation": {
      "type":"object","additionalProperties":false,"required":["thresholds","measurements","verdict","verdict_basis","exclusions","conflicts"],
      "properties":{"thresholds":{"type":"object","minProperties":1},"measurements":{"type":"object"},"verdict":{"enum":["PASS","FAIL","BLOCKED","KILLED"]},"verdict_basis":{"type":"string","minLength":1},"exclusions":{"type":"array","items":{"type":"string"}},"conflicts":{"type":"array","items":{"type":"string"}}}
    },
    "rollback": {
      "type":"object","additionalProperties":false,"required":["triggered","target","action","outcome","evidence_refs"],
      "properties":{"triggered":{"type":"boolean"},"target":{"type":"string","minLength":1},"action":{"type":"string","minLength":1},"outcome":{"enum":["NOT_REQUIRED","SUCCEEDED","FAILED","BLOCKED","NOT_RUN"]},"evidence_refs":{"type":"array","items":{"type":"string"}}}
    },
    "producer": {"type":"object","additionalProperties":false,"required":["orchestrator","host_class"],"properties":{"orchestrator":{"const":"tools/gates/stage_evidence.py"},"host_class":{"type":"string","minLength":1}}},
    "signatures": {"type":"array","items":{"type":"object","additionalProperties":false,"required":["role","key_id","signature","signed_bundle_sha256"],"properties":{"role":{"type":"string","minLength":1},"key_id":{"type":"string","minLength":1},"signature":{"type":"string","minLength":1},"signed_bundle_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}}
  },
  "$defs": {"hashed_file":{"type":"object","additionalProperties":false,"required":["path","bytes","sha256"],"properties":{"path":{"type":"string","minLength":1},"bytes":{"type":"integer","minimum":0},"sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}}
}

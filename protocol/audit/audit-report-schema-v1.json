{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noosphere.invalid/protocol/audit/audit-report-schema-v1.json",
  "title": "NOOSPHERE independent audit report envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_kind", "report_id", "binding", "issued_at", "expires_at", "auditor", "scope", "attachments", "findings", "limitations"],
  "properties": {
    "schema_version": {"const": 1},
    "report_kind": {"const": "noosphere-independent-audit-report"},
    "report_id": {"type": "string", "minLength": 1},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_id", "source_revision", "scope_sha256", "source_manifest_sha256", "threat_inventory_sha256", "bundle_manifest_sha256"],
      "properties": {
        "bundle_id": {"type": "string"},
        "source_revision": {"pattern": "^[0-9a-f]{40}$"},
        "scope_sha256": {"$ref": "#/$defs/hash"},
        "source_manifest_sha256": {"$ref": "#/$defs/hash"},
        "threat_inventory_sha256": {"$ref": "#/$defs/hash"},
        "bundle_manifest_sha256": {"$ref": "#/$defs/hash"}
      }
    },
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "auditor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization_id", "signing_key_id"],
      "properties": {"organization_id": {"type": "string"}, "signing_key_id": {"$ref": "#/$defs/hash"}}
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workstream_ids", "scope_exceptions"],
      "properties": {"workstream_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "scope_exceptions": {"type": "array", "items": {"type": "string"}}}
    },
    "attachments": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/hash"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "limitations": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "occurred_at", "actor_organization_id", "state", "prior_event_sha256", "evidence_refs", "event_sha256"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "occurred_at": {"type": "string", "format": "date-time"},
        "actor_organization_id": {"type": "string"},
        "state": {"enum": ["open", "acknowledged", "remediation_submitted", "retest_failed", "resolved_verified"]},
        "prior_event_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "event_sha256": {"$ref": "#/$defs/hash"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "workstream_id", "severity", "title", "description", "lifecycle_events"],
      "properties": {
        "finding_id": {"type": "string", "minLength": 1},
        "workstream_id": {"type": "string"},
        "severity": {"enum": ["S1", "S2", "S3", "S4"]},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "lifecycle_events": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/event"}}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "NOOS/RELEASE/MANIFEST/V1",
  "title": "NOOSPHERE Release Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","manifest_kind","release","source","identity","clients","verifiers","toolchain_locks","schema_roots","artifact_hashes","gate_verdicts","unresolved_findings","signatures","evidence_appendix"],
  "properties": {
    "schema_version":{"const":1}, "manifest_kind":{"const":"noosphere-release-manifest"}, "_comment":{"type":"string"},
    "release":{"type":"object","additionalProperties":false,"required":["version","channel","date","protocol_version","api_version"],"properties":{"version":{"type":"string","minLength":1},"channel":{"enum":["devnet","testnet","beta","stable"]},"date":{"type":"string","pattern":"^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},"protocol_version":{"const":"v1"},"api_version":{"const":"v1"}}},
    "source":{"type":"object","additionalProperties":false,"required":["corpus_source_index_root","spec_revision","plan_revision","repo_revision"],"properties":{"corpus_source_index_root":{"$ref":"#/$defs/hashOrPlaceholder"},"spec_revision":{"type":"string","minLength":1},"plan_revision":{"type":"string","minLength":1},"repo_revision":{"type":"string","minLength":1}}},
    "identity":{"type":"object","required":["chain_name","is_test_network","parameter_manifest_hash","chain_id","bitcoin_anchor","dkg_root","genesis_hash"],"properties":{"_comment":{"type":"string"},"chain_name":{"type":"string","pattern":"^noos-[a-z0-9-]+$"},"is_test_network":{"type":"boolean"},"parameter_manifest_hash":{"$ref":"#/$defs/hashOrPlaceholder"},"chain_id":{"$ref":"#/$defs/hashOrPlaceholder"},"bitcoin_anchor":{"type":"object","required":["height","block_hash_internal_order"],"properties":{"height":{"type":"integer","minimum":0},"block_hash_internal_order":{"$ref":"#/$defs/hashOrPlaceholder"}}},"dkg_root":{"$ref":"#/$defs/hashOrPlaceholder"},"genesis_hash":{"$ref":"#/$defs/hashOrPlaceholder"}}},
    "clients":{"type":"array","minItems":2,"items":{"type":"object","required":["name","family","role","revision","binary_hashes"]}},
    "verifiers":{"type":"array","minItems":1,"items":{"type":"object","required":["verifier_id","family","revision","verifier_hash"]}},
    "toolchain_locks":{"type":"object","required":["rustc","cargo_lock_hash","go","go_sum_hash","python","repro_policy","repro_policy_hash","builders"],"properties":{"rustc":{"type":"string"},"cargo_lock_hash":{"$ref":"#/$defs/hashOrPlaceholder"},"go":{"type":"string"},"go_sum_hash":{"$ref":"#/$defs/hashOrPlaceholder"},"python":{"type":"string"},"repro_policy":{"const":"protocol/release/repro-policy-v1.toml"},"repro_policy_hash":{"$ref":"#/$defs/hashOrPlaceholder"},"builders":{"type":"array","minItems":2,"items":{"type":"object","required":["id","platforms","independent_operator"],"properties":{"id":{"type":"string"},"platforms":{"type":"array","minItems":1,"items":{"enum":["windows-x86_64","linux-x86_64","linux-aarch64"]}},"independent_operator":{"type":"string"}}}}},
    "schema_roots":{"type":"object","additionalProperties":false,"required":["claim_registry_root","crypto_domains_root","constants_root","openapi_v1_root","api_vectors_root","telemetry_v1_root","telemetry_fixtures_root","conformance_vector_root","genesis_vector_root"],"properties":{"claim_registry_root":{"$ref":"#/$defs/hashOrPlaceholder"},"crypto_domains_root":{"$ref":"#/$defs/hashOrPlaceholder"},"constants_root":{"$ref":"#/$defs/hashOrPlaceholder"},"openapi_v1_root":{"$ref":"#/$defs/hashOrPlaceholder"},"api_vectors_root":{"$ref":"#/$defs/hashOrPlaceholder"},"telemetry_v1_root":{"$ref":"#/$defs/hashOrPlaceholder"},"telemetry_fixtures_root":{"$ref":"#/$defs/hashOrPlaceholder"},"conformance_vector_root":{"$ref":"#/$defs/hashOrPlaceholder"},"genesis_vector_root":{"$ref":"#/$defs/hashOrPlaceholder"}}},
    "artifact_hashes":{"type":"object","minProperties":1,"additionalProperties":{"$ref":"#/$defs/hashOrPlaceholder"}},
    "gate_verdicts":{"type":"array","minItems":1,"items":{"type":"object","required":["gate","claim_id","verdict","evidence_root","date"],"properties":{"gate":{"enum":["G0","G1","G2","G3","G4","G5"]},"claim_id":{"type":"string"},"verdict":{"enum":["PENDING","PASS","FAIL","KILLED","BLOCKED"]},"evidence_root":{"$ref":"#/$defs/hashOrPlaceholder"},"date":{"type":"string"}}}},
    "unresolved_findings":{"type":"array","items":{"type":"object","required":["finding_id","severity","summary","owner","status"]}},
    "signatures":{"type":"array","minItems":2,"maxItems":2,"items":{"type":"object","additionalProperties":false,"required":["role","key_id","signature_ed25519_hex"],"properties":{"role":{"enum":["release-owner","independent-build-reviewer"]},"key_id":{"type":"string","minLength":1},"signature_ed25519_hex":{"type":"string","anyOf":[{"pattern":"^[0-9a-f]{128}$"},{"const":"PENDING_SIGNATURE"}]}}}},
    "evidence_appendix":{"type":"object","additionalProperties":false,"required":["_comment","entries"],"properties":{"_comment":{"type":"string"},"entries":{"type":"array","items":{"$ref":"#/$defs/evidenceEntry"}}}}
  },
  "$defs": {
    "hashOrPlaceholder":{"type":"string","anyOf":[{"pattern":"^[0-9a-f]{64}$"},{"pattern":"^(PENDING|OWNER_BLOCKED)(_[A-Z0-9_]+)?$"}]},
    "evidenceEntry":{"type":"object","additionalProperties":false,"required":["entry_id","phase","command","cwd","revision","toolchain","fixtures_seeds","started","ended","exit_code","raw_log_hashes","thresholds","verdict","exclusions_conflicts","rollback_outcome","supersedes"],"properties":{"entry_id":{"type":"string","minLength":1},"phase":{"type":"string"},"command":{"type":"string"},"cwd":{"type":"string"},"revision":{"type":"string"},"toolchain":{"type":"object"},"fixtures_seeds":{"type":"array"},"started":{"type":"string"},"ended":{"type":"string"},"exit_code":{"type":"integer"},"raw_log_hashes":{"type":"array","items":{"pattern":"^[0-9a-f]{64}$"}},"thresholds":{"type":"object"},"verdict":{"enum":["PASS","FAIL","BLOCKED"]},"exclusions_conflicts":{"type":"array"},"rollback_outcome":{"type":"string"},"supersedes":{"type":["string","null"]}}}
  }
}
}

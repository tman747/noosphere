{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindchain.network/noosphere/protocol/claims/registry.schema.json",
  "title": "MindChain/NOOSPHERE claim registry",
  "description": "Machine-readable honesty ledger per plan \u00a71.3-1.4: every ClaimRecord from the frozen chapter 04 (C:/tmp/noosphere/04-experiments-and-falsifiers.md) plus every binding addendum row (04-addendum-A.md). Six independent dimensions per claim; a changed threshold creates a NEW claim_id; no flattened status may erase partial, negative, withdrawn, or retired history. A THEORY claim without a falsifier (kill_threshold) is invalid.",
  "type": "object",
  "required": [
    "schema_version",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "minItems": 40,
      "items": {
        "$ref": "#/$defs/claim"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "claim": {
      "type": "object",
      "required": [
        "claim_id",
        "mechanism_id",
        "evidence_label",
        "implementation_status",
        "evidence_status",
        "lifecycle",
        "local_implementation_state",
        "local_evidence_state",
        "owner_blockers",
        "external_blockers",
        "result",
        "enabled",
        "claim",
        "non_claims",
        "protected_property",
        "adversary",
        "dependencies",
        "source_required_assumptions",
        "prerequisites",
        "canonical_statement_ref",
        "implementation_hashes",
        "verifier_hashes",
        "client_verifier_families",
        "generators_fixtures",
        "metric",
        "statistical_power",
        "pass_threshold",
        "kill_threshold",
        "gate",
        "result_artifact_roots",
        "negative_result_status",
        "last_recalibration_height",
        "rollback",
        "owner",
        "red_team_entries",
        "date",
        "scope",
        "provenance",
        "supersedes",
        "actionable",
        "command",
        "evidence_root",
        "evidence_sha256",
        "expected_result",
        "rollback_command",
        "reproduction_command"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "mechanism_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_label": {
          "enum": [
            "BUILDABLE",
            "THEORY",
            "DREAM"
          ]
        },
        "implementation_status": {
          "enum": [
            "NOT_STARTED",
            "PARTIAL",
            "IMPLEMENTED"
          ]
        },
        "evidence_status": {
          "enum": [
            "UNMEASURED",
            "MEASURED_LAB",
            "INDEPENDENTLY_REPRODUCED",
            "AUDITED"
          ]
        },
        "local_implementation_state": {
          "enum": [
            "IMPLEMENTED",
            "PARTIAL",
            "MISSING"
          ]
        },
        "local_evidence_state": {
          "enum": [
            "VERIFIED",
            "PARTIAL",
            "MISSING"
          ]
        },
        "owner_blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "external_blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "lifecycle": {
          "enum": [
            "DEFINED",
            "ACTIVE",
            "DISABLED",
            "RETIRED",
            "WITHDRAWN"
          ]
        },
        "result": {
          "enum": [
            "UNTESTED",
            "PARTIAL",
            "PASSED",
            "KILLED"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "non_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protected_property": {
          "type": "string",
          "minLength": 1
        },
        "adversary": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_required_assumptions": {
          "type": "string",
          "minLength": 1
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonical_statement_ref": {
          "type": "object",
          "required": [
            "file",
            "section",
            "version"
          ],
          "properties": {
            "file": {
              "type": "string",
              "minLength": 1
            },
            "section": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "implementation_hashes": {
          "type": "object"
        },
        "verifier_hashes": {
          "type": "object"
        },
        "client_verifier_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "generators_fixtures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "statistical_power": {
          "type": "string",
          "minLength": 1
        },
        "pass_threshold": {
          "type": "string",
          "minLength": 1
        },
        "kill_threshold": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "type": "string",
          "pattern": "^G[0-5]$"
        },
        "result_artifact_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "negative_result_status": {
          "type": "string",
          "minLength": 1
        },
        "last_recalibration_height": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "red_team_entries": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^RT-[A-Z]+-[0-9]{3}$"
          }
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "type": "string",
          "minLength": 1
        },
        "supersedes": {
          "type": [
            "string",
            "null"
          ]
        },
        "actionable": {
          "type": "boolean"
        },
        "command": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_root": {
          "type": "string",
          "pattern": "^evidence/claim-matrix/"
        },
        "evidence_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(PENDING|[0-9a-f]{64})$"
        },
        "expected_result": {
          "enum": [
            "IMPLEMENTED",
            "PASSED",
            "KILLED",
            "DISABLED",
            "EXTERNAL_BLOCKED",
            "LOCAL_MISSING"
          ]
        },
        "rollback_command": {
          "type": "string",
          "minLength": 1
        },
        "reproduction_command": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "evidence_label": {
                "const": "THEORY"
              }
            }
          },
          "then": {
            "properties": {
              "kill_threshold": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kill_threshold"
            ]
          }
        }
      ]
    }
  }
}

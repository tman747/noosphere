{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindchain.network/noosphere/protocol/claims/wwm-registry.schema.json",
  "title": "World Wide Mind experimental claim registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "architecture", "controls_enabled", "claims"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "architecture": { "const": "docs/world-wide-mind-architecture-and-rd-plan.md" },
    "controls_enabled": { "const": false },
    "claims": {
      "type": "array",
      "minItems": 22,
      "maxItems": 22,
      "items": { "$ref": "#/$defs/claim" }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "mechanism_id",
        "implementation_status",
        "evidence_status",
        "enabled",
        "protected_property",
        "adversary",
        "dependencies",
        "metric",
        "pass_threshold",
        "kill_threshold",
        "command",
        "rollback",
        "owner_blockers",
        "external_blockers",
        "canonical_ref"
      ],
      "properties": {
        "claim_id": { "type": "string", "pattern": "^E-WWM-(0[1-9]|1[0-9]|2[0-2])$" },
        "mechanism_id": { "type": "string", "minLength": 1 },
        "implementation_status": { "enum": ["NOT_STARTED", "PARTIAL", "IMPLEMENTED"] },
        "evidence_status": { "enum": ["UNMEASURED", "MEASURED_LAB", "INDEPENDENTLY_REPRODUCED", "AUDITED", "KILLED"] },
        "enabled": { "const": false },
        "protected_property": { "type": "string", "minLength": 1 },
        "adversary": { "type": "string", "minLength": 1 },
        "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "metric": { "type": "string", "minLength": 1 },
        "pass_threshold": { "type": "string", "minLength": 1 },
        "kill_threshold": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "pattern": "^python tools/gates/run_wwm_claim.py --claim E-WWM-(0[1-9]|1[0-9]|2[0-2])$" },
        "rollback": { "type": "string", "minLength": 1 },
        "owner_blockers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "external_blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "canonical_ref": { "type": "string", "pattern": "^docs/world-wide-mind-architecture-and-rd-plan.md#e-wwm-" }
      }
    }
  }
}
